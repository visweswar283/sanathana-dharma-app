# ─────────────────────────────────────────────
# LOCAL DEV (no API key needed)
# ─────────────────────────────────────────────
# Leave ANTHROPIC_API_KEY empty OR set MOCK_MODE=true
# The server will stream pre-written Hanuma responses so you can
# test the full UI without any API calls.
ANTHROPIC_API_KEY=
MOCK_MODE=true

# ─────────────────────────────────────────────
# REAL AI (set your key, disable mock mode)
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# MOCK_MODE=false

PORT=3000
NODE_ENV=development

# Default JWT secret for local dev — CHANGE THIS IN PRODUCTION
JWT_SECRET=dev-secret-key-change-in-production-32chars!!
JWT_EXPIRES_IN=7d

ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

# ─────────────────────────────────────────────
# VOICE MODE (ElevenLabs TTS) — optional
# ─────────────────────────────────────────────
# Leave empty to disable voice mode (toggle will be hidden in app)
# Sign up free at elevenlabs.io — 10,000 chars/month on free tier
ELEVENLABS_API_KEY=
# Default voice: Adam (deep, resonant) — replace with your custom Hanuma voice ID
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
